FROM node:22-slim

WORKDIR /app

# Copy agent package files and install dependencies
COPY agent/package.json agent/package-lock.json* ./agent/
RUN cd agent && npm install

# Copy agent source
COPY agent/ ./agent/

# Create persistent data dir (mount Railway volume at /app/data)
RUN mkdir -p /app/data

# Symlink all runtime state files into /app/data so they survive container restarts
RUN ln -sf /app/data/agent_log.json /app/agent_log.json
RUN ln -sf /app/data/swarm_state.json /app/swarm_state.json
RUN ln -sf /app/data/swarm_events.json /app/swarm_events.json
RUN ln -sf /app/data/judge_flow_state.json /app/judge_flow_state.json

WORKDIR /app/agent

CMD ["npx", "tsx", "src/swarm.ts"]
