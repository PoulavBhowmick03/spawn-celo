# =============================================================
# Spawn Protocol - Mantle Edition
# Copy this file to .env and fill in all required values.
# =============================================================

# ------------------------------------------------------------------
# Wallets  (use burner keys — NEVER commit funded keys to git)
# ------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=0x...          # deployer/operator EOA — deploys contracts, allowed in LineageRegistry
TREASURY_PRIVATE_KEY=0x...          # wallet holding USDe to seed child agents ($15 each)
CHILD_GAS_STIPEND_MNT=0.05          # MNT sent to each child wallet for live Aave tx gas
# CHILD_GAS_FUNDER_PRIVATE_KEY=0x... # optional; defaults to DEPLOYER_PRIVATE_KEY
# VERIFY_CHILD_PRIVATE_KEY=0x...     # optional burner key for agent/src/verify-live-vote.ts

# ------------------------------------------------------------------
# RPC & Explorer
# ------------------------------------------------------------------
MANTLE_RPC=https://rpc.mantle.xyz
MANTLE_EXPLORER_API_KEY=            # from explorer.mantle.xyz — used for forge verify-contract

# ------------------------------------------------------------------
# Mantle mainnet DeFi (verified addresses, do not change)
# ------------------------------------------------------------------
AAVE_POOL_ADDRESS=0x458F293454fE0d67EC0655f3672301301DD51422
USDE_ADDRESS=0x5d3a1Ff2b6BAb83b63cd9AD0787074081a52ef34
USDE_ATOKEN=0xb9aCA933C9c0aa854a6DBb7b12f0CC3FdaC15ee7
USDE_DECIMALS=18
AAVE_USDE_BENCHMARK=4.50  # fallback only — live benchmark is read dynamically from Aave
                           # at each spawn. Only used if RPC call fails.
METH_ADDRESS=                        # optional forward-compatible route; leave blank unless verified
METH_DECIMALS=18
USDC_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
MOE_ROUTER_ADDRESS=0xafb85a12babfafabfe1a518594492d5a830e782a  # Merchant Moe LBRouter (verified mantlescan.xyz)

# ------------------------------------------------------------------
# Spawn Protocol contracts on Mantle mainnet
# ------------------------------------------------------------------
SPAWN_FACTORY_ADDRESS=0x94171e5D54792149E14fFa19197e3c17E263C740
LINEAGE_REGISTRY_ADDRESS=0x0466c58d7955cFdfa9E2070077D2f5E26561b59E
CHILD_AGENT_IMPLEMENTATION=0xD2d79F4A19E0D77267aBe80d85c33630d0923F72

# ------------------------------------------------------------------
# AI + Storage
# ------------------------------------------------------------------
VENICE_API_KEY=                     # from venice.ai/settings/api — used for yield reasoning + post-mortems
FILEBASE_API_KEY=                   # Filebase S3 access key — IPFS-backed bucket
FILEBASE_SECRET=                    # Filebase S3 secret key
FILEBASE_BUCKET=spawn-yield         # Filebase bucket name (IPFS storage type)

# ------------------------------------------------------------------
# Live-mode flags  (all default to dry-run; set to "true" for mainnet)
# ------------------------------------------------------------------
# ALLOW_LIVE_SPAWN=true             # broadcast spawnChild() txs
# ALLOW_LIVE_RECALL=true            # broadcast recallChild() + pushCID() txs
# ALLOW_LIVE_CHILD_WRITES=true      # child agents broadcast Aave supply/withdraw txs
# ALLOW_LIVE_GENERATION_POSTS=true  # broadcast postGenerationResult() txs

# ------------------------------------------------------------------
# Runtime tuning
# ------------------------------------------------------------------
SWARM_CHILD_COUNT=5
CHILD_CYCLE_INTERVAL_MS=30000
PARENT_EVALUATION_INTERVAL_MS=75000
RISK_THRESHOLD=0.5   # score below this for 2 consecutive cycles = terminated
BACKTEST_FORCE_SYNTHETIC=true  # skip archive node fetch; use OU synthetic data (default true)
                     # range: -inf to ~8.0. 0.5 requires slight positive performance.
                     # 3.0 was too aggressive for small positions (terminated every 2 cycles).
CHILD_STARTING_USD=1000
JUDGE_FLOW_CONTROL_PORT=8787

# ------------------------------------------------------------------
# Optional overrides
# ------------------------------------------------------------------
IPFS_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs
ERC8004_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ------------------------------------------------------------------
# Dashboard
# ------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_SPAWN_FACTORY_ADDRESS=0x94171e5D54792149E14fFa19197e3c17E263C740
NEXT_PUBLIC_LINEAGE_REGISTRY_ADDRESS=0x0466c58d7955cFdfa9E2070077D2f5E26561b59E
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
