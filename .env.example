# =============================================================
# Spawn Protocol — Celo Hedge Swarm
# Celo Onchain Agents Hackathon (deadline June 15, 2026, 9 AM GMT)
#
# Copy to .env and fill in the required values.
# Contract/protocol addresses are NOT env vars — they live in
# agent/src/chains/celo/addresses.ts, each with a source-URL comment.
# =============================================================

# ------------------------------------------------------------------
# Wallet  (use a BURNER mnemonic — NEVER commit funded keys to git)
# ------------------------------------------------------------------
MNEMONIC=                            # BIP-39 12-word phrase
                                     # HD index 0 = orchestrator, 1-29 = swarm agents, 30 = signal oracle

# ------------------------------------------------------------------
# Celo network
# ------------------------------------------------------------------
CELO_RPC_URL=https://forno.celo.org
CELO_RPC_URL_BACKUP=                 # forno rate-limits; add a drpc/ankr/quicknode Celo endpoint
CELOSCAN_API_KEY=                    # from celoscan.io API section — used for forge verify-contract

# ------------------------------------------------------------------
# Budget caps (enforced in code — agent/src/chains/celo/budget.ts)
# ------------------------------------------------------------------
TOTAL_BUDGET_USD=50                  # hard total cap; kill switch fires automatically if exceeded
MAX_AGENT_BALANCE_USD=5              # per-agent wallet cap; fund only up to this per agent
MAX_TX_USD=5                         # refuse any single tx moving more than this
MAX_SLIPPAGE_BPS=100                 # 1% slippage cap on every Mento swap

# ------------------------------------------------------------------
# Swarm tuning
# ------------------------------------------------------------------
EPOCH_HOURS=4                        # evaluate → cull → spawn cycle length
TICK_MINUTES=60                      # mid-epoch re-evaluation cadence (acts only when thresholds fire)

# ------------------------------------------------------------------
# Safety
# ------------------------------------------------------------------
KILL_SWITCH=                         # set to "true" to unwind all positions to cUSD and halt all writes
ALLOW_LIVE_SWARM=                    # set to "true" to broadcast real mainnet txs (default = dry-run)

# ------------------------------------------------------------------
# x402 signal oracle (Phase 6)
# ------------------------------------------------------------------
SIGNAL_PORT=8402                     # HTTP port for the oracle; Fly.io overrides this to $PORT
SIGNAL_URL=http://127.0.0.1:8402/signal  # where swarm agents buy FX/APY signals at $0.002/call
THIRDWEB_CLIENT_ID=                  # optional: thirdweb API client ID
THIRDWEB_SECRET_KEY=                 # optional: thirdweb secret (x402 facilitator fallback)

# ------------------------------------------------------------------
# Fly.io deployment (see fly.celo.toml + Dockerfile.celo)
# ------------------------------------------------------------------
GITHUB_PAT=                          # GitHub fine-grained PAT, repo write on PoulavBhowmick03/spawn-celo
                                     # Used by publishDocs() to push state + epoch reports each cycle
